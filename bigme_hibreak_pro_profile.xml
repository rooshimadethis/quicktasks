<?xml version="1.0" encoding="utf-8"?>
<d:devices xmlns:d="http://schemas.android.com/sdk/devices/1">
  <d:device>
    <d:name>Bigme Hibreak Pro</d:name>
    <d:manufacturer>Bigme</d:manufacturer>
    <d:hardware>
      <d:screen>
        <d:screen-size>normal</d:screen-size>
        <d:diagonal-length>6.13</d:diagonal-length>
        <d:screen-ratio>long</d:screen-ratio>
        <d:pixel-density>xhdpi</d:pixel-density>
        <d:dimensions>
          <d:x-dimension>824</d:x-dimension>
          <d:y-dimension>1648</d:y-dimension>
        </d:dimensions>
        <d:xdpi>300.0</d:xdpi>
        <d:ydpi>300.0</d:ydpi>
        <d:touch>
          <d:multitouch>jazz-hands</d:multitouch>
          <d:mechanism>finger</d:mechanism>
          <d:screen-type>capacitive</d:screen-type>
        </d:touch>
      </d:screen>
      <d:networking>
        Wifi
        Bluetooth
        NFC
      </d:networking>
      <d:sensors>
        Accelerometer
        Gyroscope
        Compass
        GPS
        LightSensor
        ProximitySensor
      </d:sensors>
      <d:mic>true</d:mic>
      <d:camera>
        <d:location>back</d:location>
        <d:autofocus>true</d:autofocus>
        <d:flash>true</d:flash>
      </d:camera>
      <d:camera>
        <d:location>front</d:location>
        <d:autofocus>false</d:autofocus>
        <d:flash>false</d:flash>
      </d:camera>
      <d:keyboard>nokeys</d:keyboard>
      <d:nav>nonav</d:nav>
      <d:ram unit="GiB">8</d:ram>
      <d:buttons>soft</d:buttons>
      <d:internal-storage unit="GiB">256</d:internal-storage>
      <d:removable-storage unit="MiB">0</d:removable-storage>
      <d:cpu>multicore</d:cpu>
      <d:gpu>true</d:gpu>
      <d:abi>
        arm64-v8a
        x86_64
      </d:abi>
      <d:dock />
      <d:power-type>battery</d:power-type>
    </d:hardware>
    <d:software>
      <d:api-level>34</d:api-level>
      <d:live-wallpaper-support>true</d:live-wallpaper-support>
    </d:software>
    <d:state default="true" name="Portrait">
      <d:description>The phone in portrait view</d:description>
      <d:screen-orientation>port</d:screen-orientation>
      <d:keyboard-state>hidden</d:keyboard-state>
      <d:nav-state>hidden</d:nav-state>
    </d:state>
    <d:state name="Landscape">
      <d:description>The phone in landscape view</d:description>
      <d:screen-orientation>land</d:screen-orientation>
      <d:keyboard-state>hidden</d:keyboard-state>
      <d:nav-state>hidden</d:nav-state>
    </d:state>
  </d:device>
</d:devices>
